	title = {Managing aflatoxin contamination threats in groundnut (Arachis hypogaea L.) production in Ghana: The role of adoption of management strategies},
	year = {2024},
	journal = {Journal of Stored Products Research},
	volume = {107},
	pages = {},
	doi = {10.1016/j.jspr.2024.102335},
