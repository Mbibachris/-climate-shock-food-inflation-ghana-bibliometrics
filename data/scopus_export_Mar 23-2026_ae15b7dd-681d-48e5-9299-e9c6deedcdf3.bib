@ARTICLE{Martey2021,
	author = {Martey, Edward and Kuwornu, John K.M.},
	title = {Perceptions of Climate Variability and Soil Fertility Management Choices Among Smallholder Farmers in Northern Ghana},
	year = {2021},
	journal = {Ecological Economics},
