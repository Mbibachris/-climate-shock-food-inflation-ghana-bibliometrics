	keywords = {Amaranthus; Fermentation; Lactobacillaceae; Microbiota; Plant Leaves; Vegetables; beta carotene; distilled water; phytic acid; pyridoxine; riboflavin; sodium chloride; sucrose; thiamine; trace element; vitamin; xanthophyll; Amaranthus; Article; controlled study; correspondence analysis; fermentation; high throughput sequencing; lactic acid bacterium; Lactobacillaceae; Lactococcus; linkage clustering; microbial community; nonhuman; nutrition; pH; plant leaf; sensory analysis; sequence analysis; microflora; plant leaf; vegetable},
