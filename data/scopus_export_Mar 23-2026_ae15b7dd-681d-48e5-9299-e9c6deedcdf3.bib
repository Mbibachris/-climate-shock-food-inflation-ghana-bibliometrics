	language = {English},
	abbrev_source_title = {Agron. Sustainable Dev.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 19; All Open Access; Green Open Access; Hybrid Gold Open Access}
}

