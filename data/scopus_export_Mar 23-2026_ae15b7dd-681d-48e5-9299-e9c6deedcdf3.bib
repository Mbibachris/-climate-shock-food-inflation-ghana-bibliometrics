}

@ARTICLE{Adigun2025,
	author = {Adigun, Ismail Adebayo and Bastola, Shiksha and Choo, Innkyo and Jung, Younghun},
	title = {Unraveling climate-induced emissions and food security in Africa through greenhouse gas and water impacts across development levels},
	year = {2025},
	journal = {Journal of Environmental Management},
	volume = {393},
	pages = {},
	doi = {10.1016/j.jenvman.2025.127161},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105015435239&doi=10.1016%2Fj.jenvman.2025.127161&partnerID=40&md5=c77da0894abd3f143eb7068eb7d8931d},
	affiliations = {Department of Advanced Science and Technology Convergence, Kyungpook National University, Gyeongbuk, 742-711, South Korea},
	abstract = {Climate change poses an unprecedented threat to food security in Africa, where agricultural systems are already strained by environmental degradation and limited adaptive capacity. The continent's vulnerability is heightened by its heavy dependence on rainfed agriculture; however, a significant knowledge gap remains in understanding how climate–agriculture relationships vary across developmental contexts and geographical regions. This study investigated the relationships between climate, greenhouse gas (GHG) emissions, water availability, and food security across different development levels in Africa. By employing geographically weighted regression, meta-frontier analysis, and Granger causality tests, the research identified critical spatial variations, efficiency gaps, and key drivers affecting per-capita crop production (PCCP), a key indicator of food security. The results revealed significant regional disparities in the sensitivity of PCCP to climate variables. North Africa exhibited pronounced vulnerability to temperature stress, while East Africa displayed strong dependence on precipitation. The influence of water availability varied across regions, with positive effects observed in West Africa and negative impacts recorded in Central Africa. GHG emissions, particularly N<sub>2</sub>O and CH<sub>4</sub>, are key drivers of PCCP. Contrary to expectations, higher Human Development Index (HDI) levels do not consistently translate to enhanced food security, as evidenced by Mali's exemplary resilience, despite its low-HDI status. These findings emphasize the need for regionally tailored agricultural policies and adaptation strategies. This study supports Africa's pursuit of Sustainable Development Goals 2 (Zero Hunger) and 13 (Climate Action) through sustainable food-security strategies and climate-resilient agricultural development. © 2025 Elsevier Ltd},
	author_keywords = {Climate change; Food security; Greenhouse gas emissions; Human development index; Water availability},
	keywords = {Africa; Agriculture; Climate Change; Food Security; Food Supply; Greenhouse Gases; Humans; Central Africa; East Africa; North Africa; West Africa; Crops; Cultivation; Food security; Food supply; Geographical regions; Greenhouse gas emissions; Greenhouse gases; Sustainable development; Agricultural system; Crop production; Emission security; Food security; Greenhouse gas emissions; Greenhouses gas; Human development index; Per capita; Water availability; Water impact; agricultural development; climate change; crop production; development level; environmental degradation; food security; Granger causality test; greenhouse gas; human development index; meta-analysis; water availability; Africa; agriculture; Article; causality; Central Africa; climate; climate change; correlation analysis; crop production; environmental policy; fluid balance; food insecurity; food security; geographically weighted regression; germination rate; Granger causality analysis; greenhouse gas emission; growing season; harvest; human development; hunger; industrialization; knowledge gap; Mali; microbial activity; North Africa; precipitation; socioeconomics; soil health; soil moisture; sustainable development goal; temperature stress; vulnerability; water availability; water stress; catering service; climate change; greenhouse gas; human; Climate change},
	correspondence_address = {Y. Jung; Department of Advanced Science and Technology Convergence, Kyungpook National University, Gyeongbuk, 742-711, South Korea; email: y.jung@knu.ac.kr},
