@ARTICLE{Abdulai2025,
	author = {Abdulai, Ibrahim Abu and Osei-Amponsah, Charity and Ahmed, Abubakari},
	title = {Urban agriculture-climate change-food security nexus: does climate-smart agriculture offer hope?},
	year = {2025},
	journal = {SN Social Sciences},
	volume = {5},
	number = {7},
	pages = {},
	doi = {10.1007/s43545-025-01125-6},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105010215178&doi=10.1007%2Fs43545-025-01125-6&partnerID=40&md5=00f7b82a389fa8e73a17c7249cbcd5d0},
	affiliations = {Department of Governance and Development Management, Simon Diedong Dombo University of Business and Integrated Development Studies, WA, Bamahu, Ghana; International Water Management Institute, Accra, Ghana; Department of Urban Design and Infrastructure Studies, Simon Diedong Dombo University of Business and Integrated Development Studies, WA, Bamahu, Ghana},
	abstract = {Urban agriculture (UA) holds significant potential to bolster food security in Ghana. Also, Climate-Smart Agriculture (CSA) practices offer a promising approach to maintain food production amidst climate variability. However, decision-makers in Ghana struggle with implementing effective strategies for UA because they lack clear evidence on the actual adoption rates of CSA and its direct impact on urban food security outcomes. Inadequate information hinders their ability to create targeted policies and support systems that benefit urban farmers and enhance food security. Therefore, this study investigates the adoption of CSA practices in urban Ghana and quantifies their effect on food security. Data was analyzed using descriptive statistics, paired sample t-test, Wilcoxon Signed-Rank Test, food consumption scores, household dietary diversity scores, and thematic analysis. The results show that most urban farmers judged that climate change is impacting food production. However, a significant proportion of them perceived that food production has improved due to CSA adoption, and all households were food secure. This study provides crucial evidence of how CSA can enhance urban food security through the lens of the diffusion of innovations and entitlement theories, an area often overlooked in current research. The findings offer actionable recommendations for local governments, highlighting the urgent need for strategic land-use policies and practical CSA adoption frameworks. Decision makers should prioritize equipping urban farmers with holistic CSA practices to build inclusive and climate resilient agrifood systems that unlock the potential of urban agriculture. © The Author(s), under exclusive licence to Springer Nature Switzerland AG 2025.},
	author_keywords = {Climate change; Climate-smart agriculture; Food security; Ghana; Urban food production},
	correspondence_address = {I.A. Abdulai; Department of Governance and Development Management, Simon Diedong Dombo University of Business and Integrated Development Studies, Bamahu, WA, Ghana; email: iaabdulai@ubids.edu.gh},
	publisher = {Springer Nature},
	issn = {26629283},
	language = {English},
	abbrev_source_title = {SN Social Sci.},
	type = {Article},
