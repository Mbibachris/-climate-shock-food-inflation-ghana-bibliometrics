@ARTICLE{Nagata2022E2230282,
	author = {Nagata, Jason M. and Hampshire, Karly and Epstein, Adrienne and Lin, Feng and Zakaras, Jennifer and Murnane, Pamela and Charlebois, Edwin D. and Tsai, Alexander C. and Nash, Denis and Weiser, Sheri D.},
	title = {Analysis of Heavy Rainfall in Sub-Saharan Africa and HIV Transmission Risk, HIV Prevalence, and Sexually Transmitted Infections, 2005-2017},
	year = {2022},
