@ARTICLE{Egbebiyi2020,
	author = {Egbebiyi, Temitope Samuel and Crespo, Olivier and Lennard, Christopher and Zaroug, Modathir and Nikulin, Grigory and Harris, Ian and Price, Jeff and Forstenhäusler, Nicole and Warren, Rachel},
	title = {Investigating the potential impact of 1.5, 2 and 3 ◦C global warming levels on crop suitability and planting season over West Africa},
	year = {2020},
	journal = {PeerJ},
	volume = {2020},
	number = {3},
	pages = {},
