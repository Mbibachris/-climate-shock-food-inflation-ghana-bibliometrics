}

@ARTICLE{Sorgho2021,
	author = {Sorgho, Raissa and Jungmann, Maximilian and Souares, Aurélia and Danquah, Ina and Sauerborn, Rainer},
	title = {Climate change, health risks, and vulnerabilities in burkina faso: A qualitative study on the perceptions of national policymakers},
	year = {2021},
	journal = {International Journal of Environmental Research and Public Health},
	volume = {18},
