	correspondence_address = {I.G.K. Ansah; Isaac Gershon Kodwo Ansah, Agricultural Economics and Rural Policy Group, Wageningen University and Research, Wageningen, Hollandseweg 1, 6706, Netherlands; email: agershon@uds.edu.gh},
	publisher = {Taylor and Francis Ltd.},
