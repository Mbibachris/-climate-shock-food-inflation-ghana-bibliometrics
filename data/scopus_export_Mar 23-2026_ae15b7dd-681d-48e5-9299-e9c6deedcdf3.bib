@ARTICLE{Akinwale202323220,
	author = {Akinwale, Y.O. and Grobler, W.C.},
	title = {RESEARCH AND TECHNOLOGY INNOVATION, FOOD SECURITY AND ECONOMIC GROWTH IN NIGERIA: IMPLICATIONS FOR AGRIPRENEURS AND POLICYMAKERS},
	year = {2023},
	journal = {African Journal of Food, Agriculture, Nutrition and Development},
