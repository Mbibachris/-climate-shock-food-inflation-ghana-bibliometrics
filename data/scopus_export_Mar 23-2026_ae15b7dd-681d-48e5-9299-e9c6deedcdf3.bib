@ARTICLE{Novella20162575,
	author = {Novella, Nicholas S. and Thiaw, Wassila M.},
	title = {A seasonal rainfall performance probability tool for famine early warning systems},
	year = {2016},
	journal = {Journal of Applied Meteorology and Climatology},
	volume = {55},
	number = {12},
	pages = {2575 - 2586},
	doi = {10.1175/JAMC-D-16-0111.1},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85008500260&doi=10.1175%2FJAMC-D-16-0111.1&partnerID=40&md5=8dfbade8180f6686c085eaa885cf1965},
	affiliations = {Climate Prediction Center, NOAA/National Centers for Environmental Prediction, College Park, MD, United States; Innovim, LLC, Greenbelt, MD, United States},
	abstract = {This paper reports on the development of a new statistical tool that generates probabilistic outlooks of seasonal precipitation anomaly categories over Africa. Called the seasonal performance probability (SPP), it quantitatively evaluates the probability of precipitation to finish at predefined percent-of-normal anomaly categories corresponding to below-average (<80% of normal), average (80%-120% of normal), and above-average (>120% of normal) conditions. This is accomplished by applying methods for kernel density estimation (KDE), which compute smoothed, continuous density functions on the basis of more than 30 years of historical precipitation data from the Africa Rainfall Climatology, version 2, dataset (ARC2) for the remaining duration of a monsoon season. Discussion of various parameterizations of KDE and testing to determine optimality of density estimates (and thus performance of SPP for operational monitoring) are presented. Verification results from 2006 to 2015 show that SPP reliably provides probabilistic outcomes of seasonal rainfall anomaly categories by after the early to midstages of rain seasons for the major monsoon regions in East Africa, West Africa, and southern Africa. SPP has proven to be a useful tool by enhancing operational climate monitoring at CPC for its prognostic capability for famine early warning scenarios over Africa. These insights are anticipated to translate into better decision-making in food security, planning, and response objectives for the U.S. Agency for International Development/Famine Early Warning Systems Network (USAID/FEWS NET). © 2016 American Meteorological Society.},
	author_keywords = {Africa; Agriculture; Probability forecasts/models/distribution; Rainfall; Statistical forecasting; Vegetation atmosphere interactions},
	keywords = {East Africa; Southern Africa; West Africa; Agriculture; Atmospheric thermodynamics; Decision making; Food supply; Probability; Probability density function; Rain; Statistical mechanics; Africa; Continuous density functions; International development; Kernel Density Estimation; Probability forecasts/models/distribution; Seasonal precipitations; Statistical forecasting; Vegetation-atmosphere interactions; early warning system; famine; forecasting method; monsoon; performance assessment; probability; rainfall; Precipitation (meteorology)},
	correspondence_address = {N.S. Novella; Climate Prediction Center, National Centers for Environmental Prediction, NOAA Center for Weather and Climate Prediction, College Park, 5830 University Research Court, 20740, United States; email: nicholas.novella@noaa.gov},
