@ARTICLE{Madaki2025,
	author = {Madaki, Mustapha Yakubu and Ullah, Ayat and Ahado, Samuel and Agyemang, Sylvester Amoako and Kofi, Tulasi Oliver and Darr, Dietrich and Bavorova, Miroslava},
	title = {Small dams for climate Adaptation: Evidence from Ghana's one-village-one-dam program for water security and agro-pastoral resilience in semi-arid Africa},
	year = {2025},
