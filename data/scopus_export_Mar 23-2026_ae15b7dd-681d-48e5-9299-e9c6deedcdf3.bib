	title = {Climate and weather services can enhance Ethiopian farmers’ resilience to climate change: Economy-wide impact analysis},
	year = {2025},
	journal = {Climate Risk Management},
	volume = {49},
	pages = {},
	doi = {10.1016/j.crm.2025.100725},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009698066&doi=10.1016%2Fj.crm.2025.100725&partnerID=40&md5=41404d3570e9c155502bd5d794e16252},
	affiliations = {International Growth Centre (IGC), Addis Ababa, Ethiopia; International Research Institute for Climate and Society (IRI), NY, United States; International Livestock Research Institute (ILRI), Addis Ababa, Ethiopia; International Food Policy Research Institute (IFPRI), Addis Ababa, Ethiopia; International Livestock Research Institute (ILRI), Nairobi, Kenya; Climate Adaptation, Sustainable Agriculture and Resilience (AGRA), Nairobi, Kenya},
	abstract = {Weather and climate services (WCS) are particularly important in Sub-Saharan Africa, where weather-dependent agriculture is the main source of livelihood, and where erratic weather patterns and extreme weather events have major impacts on rural livelihoods and food security. However, despite their importance, their effects on the agriculture sector and the overall economy are not well understood. For the case of Ethiopia, we use a computable general equilibrium modeling approach with the latest Ethiopian social accounting matrix data to estimate the potential contribution of WCS to macroeconomic variables, including growth in gross domestic product nationally and by sector. The analysis incorporates results of a separate econometric analysis of household survey data from five major regions in Ethiopia, which showed WCS use is associated with increased agricultural productivity. We estimate that increased agricultural productivity associated with WCS contributes to overall economic growth of more than 6 %, with a likely positive effect on farmers’ resilience to climate variability and change. The positive impact of WCS on agricultural productivity propagate to the overall economy, as evidenced by the considerable positive effect on GDP especially from the more climate sensitive sectors such as agriculture. © 2025 The Authors},
	author_keywords = {Climate services; Computable general equilibrium model; Ethiopia; Gross domestic product},
	correspondence_address = {A. Tesfaye; International Livestock Research Institute (ILRI), Addis Ababa, Ethiopia; email: abonesh.tesfaye@gmail.com},
	publisher = {Elsevier B.V.},
	issn = {22120963},
	language = {English},
	abbrev_source_title = {Clim. Risk Manage.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Ayal2021,
