@ARTICLE{Sarr2021,
	author = {Sarr, Mare and Bezabih Ayele, Mintewab and Kimani, Mumbi E. and Ruhinduka, Remidius},
	title = {Who benefits from climate-friendly agriculture? The marginal returns to a rainfed system of rice intensification in Tanzania},
	year = {2021},
