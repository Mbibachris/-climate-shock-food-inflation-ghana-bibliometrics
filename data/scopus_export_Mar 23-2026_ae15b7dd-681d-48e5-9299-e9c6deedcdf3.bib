@ARTICLE{Yeleliere20221169,
	author = {Yeleliere, Enoch and Nyamekye, Andy Bonaventure and Antwi-Agyei, Philip and Boamah, Emmanuel Frimpong},
	title = {Strengthening climate adaptation in the northern region of Ghana: insights from a stakeholder analysis},
	year = {2022},
	journal = {Climate Policy},
	volume = {22},
