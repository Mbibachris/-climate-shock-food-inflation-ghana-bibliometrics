@ARTICLE{Sweeney201515295,
	author = {Sweeney, Sean and Ruseva, Tatyana and Estes, Lyndon and Evans, Tom},
	title = {Mapping cropland in smallholder-dominated savannas: Integrating remote sensing techniques and probabilistic modeling},
	year = {2015},
	journal = {Remote Sensing},
	volume = {7},
	number = {11},
	pages = {15295 - 15317},
	doi = {10.3390/rs71115295},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84950123056&doi=10.3390%2Frs71115295&partnerID=40&md5=583c663fe3322aec8a759d5536ef1ec4},
	affiliations = {Center for the study of Institutions, Populations and Environmental Change (CIPEC), Indiana University, Bloomington, 47408, IN, United States; Department of Government and Justice Studies, Appalachian State University, Boone, 28607, NC, United States; Department of Civil and Environmental Engineering, Princeton University, Princeton, 08544, NJ, United States; Woodrow Wilson School, Princeton University, Princeton, 08544, NJ, United States; Department of Geography, Indiana University, Bloomington, 47408, IN, United States},
	abstract = {Traditional smallholder farming systems dominate the savanna range countries of sub-Saharan Africa and provide the foundation for the region's food security. Despite continued expansion of smallholder farming into the surrounding savanna landscapes, food insecurity in the region persists. Central to the monitoring of food security in these countries, and to understanding the processes behind it, are reliable, high-quality datasets of cultivated land. Remote sensing has been frequently used for this purpose but distinguishing crops under certain stages of growth from savanna woodlands has remained a major challenge. Yet, crop production in dryland ecosystems is most vulnerable to seasonal climate variability, amplifying the need for high quality products showing the distribution and extent of cropland. The key objective in this analysis is the development of a classification protocol for African savanna landscapes, emphasizing the delineation of cropland. We integrate remote sensing techniques with probabilistic modeling into an innovative workflow. We present summary results for this methodology applied to a land cover classification of Zambia's Southern Province. Five primary land cover categories are classified for the study area, producing an overall map accuracy of 88.18%. Omission error within the cropland class is 12.11% and commission error 9.76%. © 2015 by the authors.},
	author_keywords = {Agriculture; Classification; Cropland; Food security; Land cover; Landsat; Logistic regression; Multi-temporal; Savanna; Spectral mixture analysis},
	keywords = {Agriculture; Classification (of information); Crops; Cultivation; Ecosystems; Food supply; Cropland; Food security; Land cover; LANDSAT; Logistic regressions; Multi-temporal; Savanna; Spectral mixture analysis; Remote sensing},
