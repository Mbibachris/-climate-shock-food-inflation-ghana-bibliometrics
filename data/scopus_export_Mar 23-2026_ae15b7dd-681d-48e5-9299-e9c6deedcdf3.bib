@ARTICLE{Grace2018187,
	author = {Grace, Kathryn and Hertrich, Véronique and Singare, Djeneba and Husak, Greg},
	title = {Examining rural Sahelian out-migration in the context of climate change: An analysis of the linkages between rainfall and out-migration in two Malian villages from 1981 to 2009},
