@ARTICLE{Muniappan2015148,
	author = {Muniappan, R. and Heinrichs, Elvis A.},
	title = {Feed the future IPM innovation lab: A critica l role in globa l food security},
	year = {2015},
	journal = {Outlooks on Pest Management},
	volume = {26},
