@ARTICLE{Marcos-Garcia2024775,
	author = {Marcos-Garcia, Patricia and Carmona-Moreno, Cesar and Pastori, Marco},
	title = {Intra-growing season dry–wet spell pattern is a pivotal driver of maize yield variability in sub-Saharan Africa},
	year = {2024},
	journal = {Nature Food},
	volume = {5},
	number = {9},
	pages = {775 - 786},
	doi = {10.1038/s43016-024-01040-8},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85203964231&doi=10.1038%2Fs43016-024-01040-8&partnerID=40&md5=438a47dc503a2d7946c38684620158d3},
	affiliations = {European Commission – Joint Research Centre, Ispra, Italy; Arhs Italia—External Consultant at European Commission – Joint Research Centre, Ispra, Italy},
	abstract = {Climate variability plays a crucial role in the annual fluctuations of crop yields, posing a substantial threat to food security. Maize, the main cereal in sub-Saharan Africa, has shown varied yield trends during increasingly warmer growing seasons. Here we explore how sub-seasonal dry–wet spell patterns contribute to this variability, considering the spatial heterogeneity of crop responses, to map weather-related risks at a regional level. Our results show that shifts in specific dry–wet spell patterns across growth stages influence maize yield fluctuations in sub-Saharan Africa, explaining up to 50–60% of the interannual variation, which doubles that explained by mean changes in precipitation and temperature (30–35%). Precipitation primarily drives the onset of dry spells, while the influence of temperature increases with event intensity and peaks at the start of the growing season. Our large-scale, data-limited analysis approach has the potential to inform climate-smart agriculture in developing regions. © European Union 2024.},
	keywords = {Africa South of the Sahara; Agriculture; Climate; Climate Change; Crops, Agricultural; Rain; Seasons; Temperature; Weather; Zea mays; rain; Africa south of the Sahara; article; cereal; circannual rhythm; climate; climate change; European Union; food security; growing season; growth curve; harvest; maize; nonhuman; precipitation; temperature; weather; Africa south of the Sahara; agriculture; crop; growth, development and aging; procedures; season},
