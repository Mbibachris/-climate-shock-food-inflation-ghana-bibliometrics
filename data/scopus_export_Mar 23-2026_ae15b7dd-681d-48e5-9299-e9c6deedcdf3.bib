@ARTICLE{Chanda2025,
	author = {Chanda, Hillary and Mohareb, Eugene and Peters, Michael and Harty, Chris},
	title = {Nexus between solar-PV adoption and wild food sustainability: Case of income from honey, fruits, traditional-beer, and vegetables in rural Zambia},
	year = {2025},
